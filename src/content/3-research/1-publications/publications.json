{
  "meta": {
    "id": "publications",
    "title": "Publications",
    "language": "en",
    "version": "1.0"
  },
  "header": {
    "title": "Publications",
    "lead": "Example publication page wired to the ORCID component."
  },
  "body": [
    {
      "type": "paragraph",
      "data": {
        "text": "Replace the placeholder ORCID iD below with your own to fetch public works automatically."
      }
    },
    {
      "type": "orcid",
      "data": {
        "orcidId": "0000-0000-0000-0000",
        "sections": ["works"],
        "filters": {
          "sortBy": "date-desc"
        },
        "displayOptions": {
          "showTitle": true,
          "showDetails": "full",
          "citationStyle": "ieee",
          "workMetadata": {
            "number": false
          }
        }
      }
    }
  ]
}
