{
  "meta": {
    "id": "home",
    "title": "Home",
    "language": "en",
    "version": "1.0"
  },
  "body": [
    {
      "type": "layout-row",
      "style": ["demo-hero-row"],
      "data": {
        "widths": [34, 66],
        "components": [
          {
            "type": "feature-image",
            "style": ["demo-feature-image"],
            "data": {
              "src": "src/assets/images/profile/profile-placeholder.svg",
              "alt": "Sample profile placeholder",
              "shape": "rounded",
              "shadow": true,
              "loadEffect": "fade-in",
              "zoom": false
            }
          },
          {
            "type": "layout-row",
            "style": ["demo-intro-stack"],
            "data": {
              "rows": [
                {
                  "components": [
                    {
                      "type": "paragraph",
                      "style": ["demo-kicker"],
                      "data": {
                        "text": "ReproFolio Framework"
                      }
                    }
                  ]
                },
                {
                  "components": [
                    {
                      "type": "paragraph",
                      "style": ["demo-title"],
                      "data": {
                        "text": "Schema-Driven Scientific Portfolio Starter"
                      }
                    }
                  ]
                },
                {
                  "components": [
                    {
                      "type": "paragraph",
                      "style": ["demo-lead"],
                      "data": {
                        "text": "This homepage is intentionally generic. Replace this content with your own profile, projects, and publications while keeping the framework structure unchanged."
                      }
                    }
                  ]
                },
                {
                  "components": [
                    {
                      "type": "link-groups",
                      "style": ["demo-quick-actions"],
                      "data": {
                        "columns": 1,
                        "groups": [
                          {
                            "title": "Quick actions",
                            "links": [
                              {
                                "label": "Contact",
                                "url": "{{hook:url.resolve(6-contact/contact.html)}}",
                                "external": false,
                                "icon": "contact"
                              },
                              {
                                "label": "Email",
                                "url": "{{hook:contact.emailMailto(institutional)}}",
                                "external": false,
                                "icon": "email"
                              },
                              {
                                "label": "Call",
                                "url": "{{hook:contact.phoneTelUrl(0)}}",
                                "external": false,
                                "icon": "phone"
                              }
                            ]
                          }
                        ]
                      }
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    {
      "type": "content-carousel",
      "data": {
        "title": "Latest Example Updates",
        "intro": "Demo entries generated from JSON content under src/content/1-news/.",
        "source": "1-news",
        "includeRootFiles": false,
        "exclude": ["news.json"],
        "publishedOnly": true,
        "defaultSort": "date-desc",
        "limit": 8,
        "excerptLength": 150,
        "cardMinWidth": 300,
        "viewMoreUrl": "{{hook:url.resolve(1-news/news.html)}}",
        "viewMoreLabel": "View all updates"
      }
    }
  ]
}
