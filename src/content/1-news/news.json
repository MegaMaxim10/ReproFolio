{
  "meta": {
    "id": "news",
    "title": "News",
    "language": "en",
    "version": "1.0",
    "genSubMenus": false
  },
  "header": {
    "title": "News",
    "lead": "Framework announcements, release notes, and sample content updates."
  },
  "body": [
    {
      "type": "paragraph",
      "data": {
        "text": "Use this page as a collection landing for announcements. Each post can be written as a standalone JSON page in the same folder tree."
      }
    },
    {
      "type": "content-collection",
      "data": {
        "title": "Published Updates",
        "source": "1-news",
        "includeRootFiles": false,
        "exclude": ["news.json"],
        "publishedOnly": true,
        "maxColumns": 3,
        "enableSort": true,
        "enableFilter": true,
        "defaultSort": "date-desc",
        "excerptLength": 180,
        "emptyMessage": "No published updates yet."
      }
    }
  ]
}
