{
  "meta": {
    "id": "contact",
    "title": "Contact",
    "language": "en",
    "version": "1.0"
  },
  "header": {
    "title": "Contact",
    "subtitle": "{{cfg:site.contact.fullName}}",
    "lead": "{{cfg:site.contact.role}} at {{cfg:site.contact.institution}}. Use the placeholders below as a starting point for your own contact page."
  },
  "body": [
    {
      "type": "heading",
      "data": { "level": 2, "text": "Professional Affiliation" }
    },
    {
      "type": "paragraph",
      "data": {
        "text": "{{hook:contact.profileLine}}."
      }
    },
    {
      "type": "heading",
      "data": { "level": 2, "text": "Office Location" }
    },
    {
      "type": "map",
      "data": {
        "provider": "openstreetmap",
        "title": "Office location map",
        "address": "{{cfg:site.contact.office}}",
        "latitude": "{{cfg:site.contact.coordinates.latitude}}",
        "longitude": "{{cfg:site.contact.coordinates.longitude}}",
        "height": 360
      }
    },
    {
      "type": "link-groups",
      "data": {
        "title": "Direct Contacts",
        "columns": 2,
        "groups": [
          {
            "title": "Phone",
            "links": [
              {
                "label": "{{hook:contact.phoneDisplay(0)}}",
                "url": "{{hook:contact.phoneTelUrl(0)}}",
                "external": true,
                "icon": "phone"
              }
            ]
          },
          {
            "title": "Email",
            "links": [
              {
                "label": "{{cfg:site.contact.emails.institutional}}",
                "url": "{{hook:contact.emailMailto(institutional)}}",
                "external": true,
                "icon": "email"
              }
            ]
          }
        ]
      }
    },
    {
      "type": "link-groups",
      "data": {
        "title": "Profiles",
        "columns": 2,
        "groups": [
          {
            "title": "Web",
            "links": [
              {
                "label": "{{hook:contact.socialLabel(github)}}",
                "url": "{{hook:contact.socialUrl(github)}}",
                "external": true,
                "icon": "github"
              },
              {
                "label": "{{hook:contact.socialLabel(linkedin)}}",
                "url": "{{hook:contact.socialUrl(linkedin)}}",
                "external": true,
                "icon": "linkedin"
              },
              {
                "label": "{{hook:contact.socialLabel(orcid)}}",
                "url": "{{hook:contact.socialUrl(orcid)}}",
                "external": true,
                "icon": "orcid"
              }
            ]
          }
        ]
      }
    },
    {
      "type": "heading",
      "data": { "level": 2, "text": "Send A Message" }
    },
    {
      "type": "form",
      "data": {
        "provider": "formspree",
        "endpoint": "https://formspree.io/f/xxxxxxx",
        "fields": [
          {
            "name": "name",
            "label": "Your name",
            "type": "text",
            "required": true,
            "placeholder": "e.g. Ada Lovelace",
            "autocomplete": "name",
            "validation": { "minLength": 2, "maxLength": 80 },
            "messages": {
              "required": "Please enter your name.",
              "tooShort": "Your name must contain at least 2 characters."
            }
          },
          {
            "name": "email",
            "label": "Your email",
            "type": "email",
            "required": true,
            "placeholder": "name@example.com",
            "autocomplete": "email",
            "validation": { "minLength": 6 },
            "messages": {
              "required": "Please provide your email address.",
              "typeMismatch": "Please enter a valid email address."
            }
          },
          {
            "name": "subject",
            "label": "Subject",
            "type": "text",
            "required": true,
            "placeholder": "Short summary of your request",
            "autocomplete": "off",
            "validation": { "minLength": 4, "maxLength": 120 },
            "messages": {
              "required": "Please add a subject.",
              "tooShort": "The subject must be at least 4 characters long."
            }
          },
          {
            "name": "message",
            "label": "Message",
            "type": "textarea",
            "required": true,
            "placeholder": "Describe your project, question, or collaboration proposal...",
            "validation": { "minLength": 20, "maxLength": 2000 },
            "messages": {
              "required": "Please enter your message.",
              "tooShort": "Your message must be at least 20 characters."
            }
          }
        ]
      }
    }
  ],
  "footer": {
    "notes": "Replace all placeholders with your own public contact information before production release."
  }
}
